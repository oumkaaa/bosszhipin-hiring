# Boss直聘招聘助手环境变量示例

# Python编码（Windows上强烈建议设置为utf-8）
PYTHONIOENCODING=utf-8

# 运行时目录（候选人数据存储位置）
BOSS_RUNTIME_DIR=/path/to/runtime

# Boss直聘数据目录（boss-agent-cli）
BOSS_DATA_DIR=~/.boss-agent

# Anthropic API Key（可选，用于AI兜底判断）
ANTHROPIC_API_KEY=

# CDP Chrome调试端口（可选，用于需要CDP的操作）
BOSS_CDP_URL=http://localhost:9222
